# Lab-Core Backend 環境変数サンプル
# 使い方:
# 1) このファイルを .env にコピー
# 2) 環境（ローカル開発 / 研究室運用）に応じて値を変更
# 補足:
# - 相対パスはプロジェクトルート基準で解決されます

# ------------------------------------------------------------
# サーバー基本設定
# ------------------------------------------------------------

# バックエンド API の待受ポート
# 例: 7300 (開発), 80/8080 (プロキシ構成次第)
LAB_CORE_PORT=7300

# 実行モード
# - dry-run: Docker/Git の実行をスキップ（導線テスト向け）
# - execute: Docker/Git を実行（実動作確認/本番向け）
# 例: dry-run, execute
LAB_CORE_EXECUTION_MODE=dry-run

# ------------------------------------------------------------
# 永続化・実行パス
# ------------------------------------------------------------

# SQLite DB ファイルパス
# 例: ./core/backend/data/database.sqlite
# 例: /opt/lab-core/core/database.sqlite
LAB_CORE_DB_PATH=./core/backend/data/database.sqlite

# Docker Engine ソケット
# 例: /var/run/docker.sock
# 例: /run/user/1000/docker.sock (rootless docker)
LAB_CORE_DOCKER_SOCKET=/var/run/docker.sock

# Git clone したアプリソースの配置先
# 例: ./runtime/apps
# 例: /opt/lab-core/apps
LAB_CORE_APPS_ROOT=./runtime/apps

# アプリ永続データの配置先
# 例: ./runtime/appdata
# 例: /opt/lab-core/appdata
LAB_CORE_APPDATA_ROOT=./runtime/appdata

# ------------------------------------------------------------
# ネットワーク・ドメイン設定
# ------------------------------------------------------------

# アプリ公開ホスト名を解決させる先の IP
# 例: 127.0.0.1 (ローカル開発)
# 例: 192.168.11.224 (研究室本番)
LAB_CORE_MAIN_SERVICE_IP=192.168.11.224

# ssh.<rootDomain> を解決させる先の IP
# 例: 127.0.0.1 (ローカル開発)
# 例: 192.168.11.225 (研究室本番)
LAB_CORE_SSH_SERVICE_IP=192.168.11.225

# 公開ホスト名のルートドメイン
# 例: lab.localhost (ローカル開発)
# 例: fukaya-sus.lab (研究室本番)
LAB_CORE_ROOT_DOMAIN=fukaya-sus.lab

# ------------------------------------------------------------
# 生成物（DNS/Proxy 同期）
# ------------------------------------------------------------

# 生成する Caddy 設定ファイルの出力先
# 例: ./core/backend/data/generated/Caddyfile
# 例: /opt/lab-core/core/proxy/Caddyfile.generated
LAB_CORE_PROXY_CONFIG_PATH=./core/backend/data/generated/Caddyfile

# 生成する DNS hosts ファイルの出力先
# 例: ./core/backend/data/generated/fukaya-sus.hosts
# 例: /opt/lab-core/core/dns/fukaya-sus.hosts.generated
LAB_CORE_DNS_HOSTS_PATH=./core/backend/data/generated/fukaya-sus.hosts

# 生成ファイルを置くディレクトリ
# 例: ./core/backend/data/generated
# 例: /opt/lab-core/core/generated
LAB_CORE_SYNC_DIR=./core/backend/data/generated

# ------------------------------------------------------------
# 内蔵 DNS サーバー
# ------------------------------------------------------------

# Lab-Core 内蔵 DNS サーバーを起動するか
# 例: true, false
LAB_CORE_DNS_SERVER_ENABLED=true

# DNS サーバーの bind host
# 例: 127.0.0.1 (ローカル専用)
# 例: 0.0.0.0 (LAN 公開)
LAB_CORE_DNS_BIND_HOST=127.0.0.1

# DNS サーバー待受ポート
# 例: 53
# 備考: 53 は権限が必要な場合があります
LAB_CORE_DNS_PORT=53

# 外部問い合わせを転送する upstream DNS 一覧（カンマ区切り）
# 空欄なら /etc/resolv.conf を参照し、見つからなければ 1.1.1.1 / 8.8.8.8 を使用
LAB_CORE_DNS_UPSTREAMS=

# ------------------------------------------------------------
# 設定例プリセット（必要に応じて採用）
# ------------------------------------------------------------

# [ローカル開発向け]
# LAB_CORE_EXECUTION_MODE=dry-run
# LAB_CORE_MAIN_SERVICE_IP=127.0.0.1
# LAB_CORE_SSH_SERVICE_IP=127.0.0.1
# LAB_CORE_ROOT_DOMAIN=lab.localhost
# LAB_CORE_DNS_SERVER_ENABLED=true
# LAB_CORE_DNS_BIND_HOST=127.0.0.1
# LAB_CORE_DNS_PORT=53

# [研究室運用向け]
# LAB_CORE_EXECUTION_MODE=execute
# LAB_CORE_MAIN_SERVICE_IP=192.168.11.224
# LAB_CORE_SSH_SERVICE_IP=192.168.11.225
# LAB_CORE_ROOT_DOMAIN=fukaya-sus.lab
# LAB_CORE_DNS_SERVER_ENABLED=true
# LAB_CORE_DNS_BIND_HOST=0.0.0.0
# LAB_CORE_DNS_PORT=53
