{
  "name": "lab-core",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "core/backend",
    "core/dashboard"
  ],
  "scripts": {
    "dev": "yarn dev:backend",
    "dev:backend": "yarn workspace @lab-core/backend dev",
    "dev:dashboard": "yarn workspace @lab-core/dashboard dev",
    "dev:dns": "docker compose -f infra/compose/docker-compose.dns.yml up -d dns",
    "dev:dns:down": "docker compose -f infra/compose/docker-compose.dns.yml down",
    "dev:dns:logs": "docker compose -f infra/compose/docker-compose.dns.yml logs -f dns",
    "dev:proxy": "docker compose -f infra/compose/docker-compose.proxy.yml up -d proxy && node scripts/dev/refresh-proxy-networks.mjs && docker restart labcore-dev-proxy-proxy-1",
    "dev:proxy:refresh": "node scripts/dev/refresh-proxy-networks.mjs && docker restart labcore-dev-proxy-proxy-1",
    "dev:proxy:down": "docker compose -f infra/compose/docker-compose.proxy.yml down",
    "dev:proxy:logs": "docker compose -f infra/compose/docker-compose.proxy.yml logs -f proxy",
    "maintenance:reset": "node scripts/maintenance/reset-lab-core.mjs",
    "maintenance:reset:yes": "node scripts/maintenance/reset-lab-core.mjs --yes",
    "build": "yarn workspace @lab-core/backend build && yarn workspace @lab-core/dashboard build",
    "test:register-fixtures": "bash scripts/testing/register_app_fixtures.sh",
    "test:smoke": "bash scripts/testing/run_full_system_smoke_test.sh",
    "config:init": "node scripts/config/env-wizard.mjs init",
    "config:reset": "node scripts/config/env-wizard.mjs reset"
  }
}
