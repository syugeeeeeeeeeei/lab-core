# Host settings
SERVER_IP=127.0.0.1
LAB_DOMAIN=xxx.lab
LAB_BRIDGE_NAME=lab-bridge
TZ=Asia/Tokyo

# DNS publish settings (temporary default)
DNS_HOST_PORT=5353
DNS_BIND_IP=0.0.0.0

# Nginx Proxy Manager
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# Dockge
DOCKGE_PORT=5001
DOCKGE_STACKS_DIR=/opt/stacks

# Lab-Wire Manager
MANAGER_RECONNECT_DELAY_MS=3000
